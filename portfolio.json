/* =========================================================
   DESIGN TOKENS
   ========================================================= */
:root {
  --bg: #FAF6EF;
  --bg-section: #F2EEE5;
  --surface: #FFFFFF;
  --ink: #2B2924;
  --ink-soft: #6B675E;
  --line: #E7E1D3;
  --line-strong: #D8CFB8;
  --gold: #B99A5B;
  --gold-deep: #8F7742;
  --gold-tint: #F3E9D4;
  --gold-ink: #2B2924;

  --font-display: 'Manrope', 'Inter', sans-serif;
  --font-body: 'Inter', -apple-system, sans-serif;
  --font-accent: 'Poppins', 'Inter', sans-serif;

  --container: 1200px;
  --radius: 14px;
  --radius-sm: 8px;

  --shadow-sm: 0 1px 3px rgba(43,41,36,0.06);
  --shadow-md: 0 10px 30px rgba(43,41,36,0.08);
  --shadow-lg: 0 24px 56px rgba(43,41,36,0.12);

  --ease: cubic-bezier(0.22, 1, 0.36, 1);
}

/* =========================================================
   RESET
   ========================================================= */
*, *::before, *::after { box-sizing: border-box; }
html { scroll-behavior: smooth; }
@media (prefers-reduced-motion: reduce) {
  html { scroll-behavior: auto; }
  *, *::before, *::after {
    animation-duration: 0.001ms !important;
    animation-iteration-count: 1 !important;
    transition-duration: 0.001ms !important;
    scroll-behavior: auto !important;
  }
}
body, h1, h2, h3, h4, p, figure, blockquote { margin: 0; }
ul, ol { margin: 0; padding: 0; list-style: none; }
img { max-width: 100%; display: block; }
button, input, textarea { font: inherit; color: inherit; }
a { color: inherit; text-decoration: none; }

body {
  background: var(--bg);
  color: var(--ink);
  font-family: var(--font-body);
  font-size: 16px;
  line-height: 1.65;
  -webkit-font-smoothing: antialiased;
}

.container { max-width: var(--container); margin: 0 auto; padding: 0 32px; }
.container-narrow { max-width: 780px; margin: 0 auto; padding: 0 32px; }

:focus-visible { outline: 2px solid var(--gold-deep); outline-offset: 3px; border-radius: 2px; }

.skip-link {
  position: absolute; left: -999px; top: 0;
  background: var(--gold); color: var(--gold-ink);
  padding: 12px 20px; z-index: 1000; border-radius: 0 0 8px 0;
}
.skip-link:focus { left: 0; }

/* =========================================================
   TYPE
   ========================================================= */
h1, h2, h3, h4 {
  font-family: var(--font-display);
  font-weight: 700;
  letter-spacing: -0.01em;
  line-height: 1.15;
  color: var(--ink);
}

.eyebrow {
  font-family: var(--font-accent);
  font-size: 12.5px;
  font-weight: 600;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--gold-deep);
  display: inline-block;
  margin-bottom: 14px;
}

.section-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  gap: 24px;
  margin-bottom: 40px;
}
.section-head h2 { font-size: clamp(24px, 3.2vw, 32px); }
.section-head .view-all {
  font-family: var(--font-accent);
  font-size: 13.5px;
  font-weight: 600;
  color: var(--gold-deep);
  white-space: nowrap;
  border-bottom: 1px solid var(--gold);
  padding-bottom: 2px;
  transition: opacity 0.2s var(--ease);
}
.section-head .view-all:hover { opacity: 0.65; }

.section { padding: 80px 0; }
.section-alt { background: var(--bg-section); }
@media (max-width: 700px) { .section { padding: 56px 0; } }

.reveal { opacity: 0; transform: translateY(16px); transition: opacity 0.6s var(--ease), transform 0.6s var(--ease); }
.reveal.is-visible { opacity: 1; transform: translateY(0); }

/* =========================================================
   BUTTONS
   ========================================================= */
.btn {
  display: inline-flex; align-items: center; gap: 8px;
  font-family: var(--font-accent);
  font-weight: 600; font-size: 14.5px;
  padding: 13px 26px;
  border-radius: 40px;
  border: 1px solid transparent;
  cursor: pointer;
  transition: transform 0.25s var(--ease), background 0.25s var(--ease), border-color 0.25s var(--ease), color 0.25s var(--ease);
}
.btn:hover { transform: translateY(-2px); }
.btn-primary { background: var(--ink); color: var(--bg); }
.btn-primary:hover { background: var(--gold-deep); color: #fff; }
.btn-gold { background: var(--gold); color: var(--gold-ink); }
.btn-gold:hover { background: var(--gold-deep); color: #fff; }
.btn-outline { background: transparent; border-color: var(--line-strong); color: var(--ink); }
.btn-outline:hover { border-color: var(--gold-deep); color: var(--gold-deep); }
.btn-sm { padding: 9px 18px; font-size: 13px; }

/* =========================================================
   NAV
   ========================================================= */
.nav {
  position: fixed; top: 0; left: 0; right: 0; z-index: 500;
  background: color-mix(in srgb, var(--bg) 90%, transparent);
  backdrop-filter: blur(10px);
  border-bottom: 1px solid transparent;
  transition: border-color 0.3s var(--ease), box-shadow 0.3s var(--ease);
}
.nav.is-scrolled { border-bottom-color: var(--line); box-shadow: var(--shadow-sm); }
.nav-inner { display: grid; grid-template-columns: 1fr auto 1fr; align-items: center; height: 78px; gap: 16px; }

.logo {
  font-family: var(--font-display); font-weight: 800; font-size: 18px;
  letter-spacing: -0.01em; color: var(--ink);
  justify-self: start;
}
.logo span { color: var(--gold-deep); }

.nav-links {
  display: flex; align-items: center; gap: 26px;
  justify-self: center;
}
.nav-links a {
  font-family: var(--font-accent);
  font-size: 13.5px; font-weight: 500;
  color: var(--ink-soft);
  transition: color 0.2s var(--ease);
}
.nav-links a:hover, .nav-links a.is-active { color: var(--gold-deep); }

.nav-actions { display: flex; align-items: center; gap: 12px; justify-self: end; }
.icon-btn {
  width: 40px; height: 40px; display: grid; place-items: center;
  border-radius: 50%; border: 1px solid var(--line-strong);
  background: transparent; cursor: pointer; color: var(--ink);
  transition: border-color 0.2s var(--ease), background 0.2s var(--ease);
}
.icon-btn:hover { border-color: var(--gold-deep); background: var(--gold-tint); }
.icon-btn svg { width: 17px; height: 17px; }

.nav-toggle { display: none; }
@media (max-width: 900px) {
  .nav-links {
    position: fixed; top: 78px; left: 0; right: 0;
    background: var(--bg); flex-direction: column; align-items: flex-start;
    padding: 20px 32px 28px; border-bottom: 1px solid var(--line);
    gap: 18px; transform: translateY(-8px); opacity: 0; pointer-events: none;
    transition: all 0.25s var(--ease);
  }
  .nav-links.is-open { transform: translateY(0); opacity: 1; pointer-events: auto; }
  .nav-toggle { display: grid; }
}

/* =========================================================
   SEARCH OVERLAY
   ========================================================= */
.search-overlay {
  position: fixed; inset: 0; z-index: 900;
  background: rgba(43,41,36,0.5);
  display: flex; align-items: flex-start; justify-content: center;
  padding: 90px 24px;
  opacity: 0; pointer-events: none;
  transition: opacity 0.25s var(--ease);
}
.search-overlay.is-open { opacity: 1; pointer-events: auto; }

.search-panel {
  background: var(--surface); border-radius: var(--radius);
  width: 100%; max-width: 620px; box-shadow: var(--shadow-lg);
  max-height: 76vh; display: flex; flex-direction: column; overflow: hidden;
}
.search-input-row { display: flex; align-items: center; gap: 12px; padding: 20px 22px; border-bottom: 1px solid var(--line); }
.search-input-row svg { width: 19px; height: 19px; color: var(--ink-soft); flex-shrink: 0; }
.search-input-row input { flex: 1; border: none; outline: none; background: none; font-size: 16px; }
.search-close { border: none; background: none; cursor: pointer; color: var(--ink-soft); width: 28px; height: 28px; }

.search-results { overflow-y: auto; padding: 8px; }
.search-result {
  display: block; padding: 14px 14px; border-radius: var(--radius-sm);
  transition: background 0.2s var(--ease);
}
.search-result:hover { background: var(--gold-tint); }
.search-result .sr-cat { font-family: var(--font-accent); font-size: 11px; text-transform: uppercase; letter-spacing: 0.05em; color: var(--gold-deep); font-weight: 600; }
.search-result h4 { font-size: 15.5px; margin: 4px 0 3px; }
.search-result p { font-size: 13.5px; color: var(--ink-soft); }
.search-empty { padding: 32px 20px; text-align: center; color: var(--ink-soft); font-size: 14.5px; }

/* =========================================================
   HERO
   ========================================================= */
.hero { padding: 168px 0 90px; }
.hero-grid { display: grid; grid-template-columns: 1.1fr 0.9fr; gap: 60px; align-items: center; }
@media (max-width: 940px) { .hero-grid { grid-template-columns: 1fr; gap: 44px; } }

.hero h1 { font-size: clamp(38px, 6vw, 64px); margin-bottom: 22px; }
.hero-lede { font-size: 18px; color: var(--ink-soft); max-width: 480px; margin-bottom: 34px; }
.hero-ctas { display: flex; flex-wrap: wrap; gap: 12px; }

.hero-illustration { display: flex; align-items: center; justify-content: center; }
.hero-illustration svg { width: 100%; max-width: 380px; height: auto; }

/* =========================================================
   ARTICLE CARDS
   ========================================================= */
.card-thumb {
  border-radius: var(--radius); overflow: hidden;
  aspect-ratio: 16/10; position: relative;
}
.grad-lifestyle-1 { background: linear-gradient(135deg, #E9D9C2 0%, #B99A5B 100%); }
.grad-lifestyle-2 { background: linear-gradient(135deg, #F0E4CF 0%, #C9AD78 100%); }
.grad-lifestyle-3 { background: linear-gradient(135deg, #DCC9A3 0%, #8F7742 100%); }
.grad-tech-1 { background: linear-gradient(135deg, #D8D3C4 0%, #4B4A45 100%); }
.grad-tech-2 { background: linear-gradient(135deg, #E4DFD1 0%, #6B675E 100%); }
.grad-tech-3 { background: linear-gradient(135deg, #C7C2B2 0%, #2B2924 100%); }
.grad-news-1 { background: linear-gradient(135deg, #EFE7D6 0%, #A98A52 100%); }
.grad-news-2 { background: linear-gradient(135deg, #E2D6BC 0%, #8F7742 100%); }
.grad-news-3 { background: linear-gradient(135deg, #D9CDB2 0%, #6B5B37 100%); }
.grad-career-1 { background: linear-gradient(135deg, #ECE3D0 0%, #B99A5B 100%); }
.grad-career-2 { background: linear-gradient(135deg, #E0D5BC 0%, #7C6739 100%); }
.grad-career-3 { background: linear-gradient(135deg, #D3C7AA 0%, #5B4C2C 100%); }
.grad-health-1 { background: linear-gradient(135deg, #E7DCC5 0%, #9C8656 100%); }
.grad-health-2 { background: linear-gradient(135deg, #EFE6D2 0%, #B3986A 100%); }
.grad-health-3 { background: linear-gradient(135deg, #DACCA9 0%, #77613A 100%); }
.grad-kids-1 { background: linear-gradient(135deg, #F1E9D8 0%, #C4AA78 100%); }
.grad-kids-2 { background: linear-gradient(135deg, #E6DAC0 0%, #A88C58 100%); }
.grad-kids-3 { background: linear-gradient(135deg, #DFD2B4 0%, #8A7245 100%); }

.card-cat-tag {
  position: absolute; top: 14px; left: 14px;
  font-family: var(--font-accent); font-size: 11px; font-weight: 600;
  letter-spacing: 0.04em; text-transform: uppercase;
  background: rgba(255,255,255,0.92); color: var(--ink);
  padding: 5px 11px; border-radius: 20px;
}

.article-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 30px; }
@media (max-width: 980px) { .article-grid { grid-template-columns: repeat(2, 1fr); } }
@media (max-width: 640px) { .article-grid { grid-template-columns: 1fr; } }

.article-card { display: flex; flex-direction: column; gap: 14px; }
.article-card h3 { font-size: 19px; line-height: 1.35; transition: color 0.2s var(--ease); }
.article-card:hover h3 { color: var(--gold-deep); }
.article-card p.excerpt { font-size: 14.5px; color: var(--ink-soft); }
.article-meta {
  display: flex; gap: 12px; align-items: center;
  font-family: var(--font-accent); font-size: 12.5px; color: var(--ink-soft);
}
.article-meta .dot { width: 3px; height: 3px; border-radius: 50%; background: var(--line-strong); }
.read-more { font-family: var(--font-accent); font-size: 13.5px; font-weight: 600; color: var(--gold-deep); display: inline-flex; align-items: center; gap: 6px; }
.read-more svg { width: 14px; height: 14px; transition: transform 0.2s var(--ease); }
.article-card:hover .read-more svg { transform: translateX(3px); }

/* =========================================================
   FEATURED ARTICLE
   ========================================================= */
.featured-article {
  display: grid; grid-template-columns: 1.1fr 0.9fr; gap: 44px; align-items: center;
  background: var(--surface); border-radius: var(--radius);
  padding: 20px; box-shadow: var(--shadow-md);
}
@media (max-width: 860px) { .featured-article { grid-template-columns: 1fr; } }
.featured-article .card-thumb { aspect-ratio: 4/3; }
.featured-article h3 { font-size: clamp(22px, 3vw, 30px); margin-bottom: 14px; }
.featured-article .excerpt { font-size: 16px; color: var(--ink-soft); margin-bottom: 18px; }
.featured-content { padding: 12px 20px 12px 4px; }
@media (max-width: 860px) { .featured-content { padding: 4px 8px 20px; } }

/* =========================================================
   CATEGORY SECTIONS
   ========================================================= */
.category-block:not(:last-child) { border-bottom: 1px solid var(--line); }

/* =========================================================
   PORTFOLIO PAGE
   ========================================================= */
.filter-row { display: flex; flex-wrap: wrap; gap: 10px; margin-bottom: 40px; }
.filter-chip {
  font-family: var(--font-accent); font-size: 13px; font-weight: 600;
  padding: 9px 18px; border-radius: 30px; border: 1px solid var(--line-strong);
  cursor: pointer; background: transparent; color: var(--ink-soft);
  transition: all 0.2s var(--ease);
}
.filter-chip.is-active, .filter-chip:hover { border-color: var(--gold-deep); background: var(--gold-tint); color: var(--gold-deep); }

.portfolio-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 24px; }
@media (max-width: 760px) { .portfolio-grid { grid-template-columns: 1fr; } }

.portfolio-card {
  background: var(--surface); border-radius: var(--radius);
  padding: 28px; box-shadow: var(--shadow-sm);
  transition: box-shadow 0.3s var(--ease), transform 0.3s var(--ease);
}
.portfolio-card:hover { box-shadow: var(--shadow-md); transform: translateY(-4px); }
.portfolio-card .niche { font-family: var(--font-accent); font-size: 11.5px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; color: var(--gold-deep); }
.portfolio-card h3 { font-size: 19px; margin: 8px 0 10px; }
.portfolio-card p.summary { font-size: 14.5px; color: var(--ink-soft); margin-bottom: 14px; }
.portfolio-card .role { font-size: 13px; color: var(--ink-soft); margin-bottom: 14px; }
.portfolio-card .role strong { color: var(--ink); }
.pf-skills { display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 16px; }
.pf-skills span { font-size: 11.5px; font-family: var(--font-accent); background: var(--gold-tint); color: var(--gold-deep); padding: 4px 10px; border-radius: 20px; }

/* =========================================================
   ARTICLE PAGE
   ========================================================= */
.article-header { padding: 150px 0 40px; }
.article-header .eyebrow { margin-bottom: 18px; }
.article-header h1 { font-size: clamp(28px, 4.5vw, 44px); margin-bottom: 20px; }
.article-byline { display: flex; align-items: center; gap: 14px; flex-wrap: wrap; font-family: var(--font-accent); font-size: 13.5px; color: var(--ink-soft); }
.article-byline strong { color: var(--ink); }

.article-hero-image { border-radius: var(--radius); aspect-ratio: 21/9; margin: 30px 0 10px; }

.share-row { display: flex; gap: 10px; margin: 24px 0 0; }
.share-row a {
  width: 38px; height: 38px; display: grid; place-items: center;
  border-radius: 50%; border: 1px solid var(--line-strong);
  color: var(--ink-soft); transition: all 0.2s var(--ease);
}
.share-row a:hover { border-color: var(--gold-deep); color: var(--gold-deep); }
.share-row svg { width: 16px; height: 16px; }

.article-body { font-size: 17.5px; line-height: 1.85; color: var(--ink); }
.article-body p { margin-bottom: 24px; }

.article-tags { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 30px; }
.article-tags span { font-family: var(--font-accent); font-size: 12px; background: var(--gold-tint); color: var(--gold-deep); padding: 5px 12px; border-radius: 20px; }

.prev-next { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-top: 50px; padding-top: 30px; border-top: 1px solid var(--line); }
@media (max-width: 640px) { .prev-next { grid-template-columns: 1fr; } }
.pn-card { display: flex; flex-direction: column; gap: 6px; padding: 18px; border-radius: var(--radius-sm); background: var(--surface); transition: background 0.2s var(--ease); }
.pn-card:hover { background: var(--gold-tint); }
.pn-card.next { text-align: right; align-items: flex-end; }
.pn-label { font-family: var(--font-accent); font-size: 11px; text-transform: uppercase; letter-spacing: 0.05em; color: var(--ink-soft); }
.pn-title { font-weight: 600; font-size: 15px; }

.newsletter-box {
  background: var(--ink); color: var(--bg);
  border-radius: var(--radius); padding: 40px; margin-top: 56px;
  display: flex; justify-content: space-between; align-items: center; gap: 24px; flex-wrap: wrap;
}
.newsletter-box h3 { color: var(--bg); font-size: 21px; margin-bottom: 6px; }
.newsletter-box p { color: rgba(250,246,239,0.7); font-size: 14px; }
.newsletter-form { display: flex; gap: 10px; flex-wrap: wrap; }
.newsletter-form input {
  padding: 12px 16px; border-radius: 30px; border: 1px solid rgba(250,246,239,0.25);
  background: rgba(250,246,239,0.08); color: var(--bg); min-width: 220px;
}
.newsletter-form input::placeholder { color: rgba(250,246,239,0.5); }
.newsletter-success { display: none; color: var(--gold); font-size: 13.5px; margin-top: 10px; }
.newsletter-success.is-visible { display: block; }

.comments-note {
  margin-top: 50px; padding: 24px; border: 1px dashed var(--line-strong);
  border-radius: var(--radius-sm); color: var(--ink-soft); font-size: 14px;
}

.related-grid { margin-top: 20px; }

/* =========================================================
   FOOTER
   ========================================================= */
.footer { padding: 60px 0 40px; border-top: 1px solid var(--line); margin-top: 40px; }
.footer-grid { display: flex; justify-content: space-between; gap: 30px; flex-wrap: wrap; margin-bottom: 30px; }
.footer-bio { max-width: 420px; }
.footer-bio .logo { display: inline-block; margin-bottom: 12px; }
.footer-bio p { font-size: 14.5px; color: var(--ink-soft); }
.footer-social { display: flex; gap: 12px; align-items: flex-start; }
.footer-social a {
  width: 38px; height: 38px; display: grid; place-items: center;
  border-radius: 50%; border: 1px solid var(--line-strong); color: var(--ink-soft);
  transition: all 0.2s var(--ease);
}
.footer-social a:hover { border-color: var(--gold-deep); color: var(--gold-deep); }
.footer-social svg { width: 16px; height: 16px; }
.footer-bottom {
  display: flex; justify-content: space-between; flex-wrap: wrap; gap: 10px;
  font-family: var(--font-accent); font-size: 12.5px; color: var(--ink-soft);
  padding-top: 24px; border-top: 1px solid var(--line);
}

/* =========================================================
   MISC PAGES
   ========================================================= */
.page-header { padding: 150px 0 50px; }
.page-header h1 { font-size: clamp(30px, 5vw, 46px); margin-bottom: 14px; }
.page-header p { color: var(--ink-soft); font-size: 16.5px; max-width: 560px; }
.back-link { display: inline-flex; align-items: center; gap: 6px; font-family: var(--font-accent); font-size: 13px; color: var(--ink-soft); margin-bottom: 20px; }
.back-link:hover { color: var(--gold-deep); }
.empty-state { padding: 40px 0; color: var(--ink-soft); }
